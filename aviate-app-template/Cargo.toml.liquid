[package]
name = "aviate-app-{{project-name}}"
{% if env == "flight" %}
edition = "2021"
version = "0.0.0"
license = "MIT OR Apache-2.0"
{% else %}
edition.workspace = true
version.workspace = true
license.workspace = true
{% endif %}
description = "{{project-name}} Aviate application"

[[bin]]
name = "{{project-name}}"
path = "src/main.rs"

{% if env == "sitl" %}
[lib]
name = "aviate_app_{{project-name | replace: "-", "_"}}"
path = "src/lib.rs"

[features]
gz-plugin = ["aviate-board-{{board}}/gz-plugin"]
default = ["gz-plugin"]

[dependencies]
# Config parsing
aviate-config = { path = "../../aviate-config" }

# Board (brings in aviate-core, aviate-runtime, aviate-hal-xil, etc.)
aviate-board-{{board}} = { path = "../../aviate-boards/{{board}}" }

# Airframe selection (specifies mixer configuration)
aviate-airframe-multirotor = { path = "../../aviate-airframes/multirotor", features = ["{{airframe}}"] }

# Test infrastructure (mission framework, world gen, etc.)
aviate-core = { path = "../../aviate-core" }
aviate-hal-xil = { path = "../../aviate-hal/xil" }
aviate-backend-gz = { path = "../../aviate-hal/xil/backends/gz" }
aviate-link = { path = "../../aviate-link" }

# Logging (SITL only)
log = "0.4"
env_logger = "0.11"
{% elsif env == "flight" %}
# Standalone package (not part of main workspace due to different target)
[workspace]

[features]
default = ["software-bootloader", "flight"]
software-bootloader = ["aviate-board-{{board}}/software-bootloader"]
# Flight mode: Real hardware (no_std compatible)
# Phase 1: Uses FakeSensors for HIL testing on real MCU
# Phase 3+: Will use real BMI088/SPL06 sensor drivers
flight = ["aviate-board-{{board}}/env-flight"]

[dependencies]
# Board (brings in HAL, drivers, etc.)
aviate-board-{{board}} = { path = "../../aviate-boards/{{board}}" }

# Runtime with flight environment (no_std compatible)
aviate-runtime = { path = "../../aviate-runtime", features = ["env-flight"] }

# Airframe selection
aviate-airframe-multirotor = { path = "../../aviate-airframes/multirotor", features = ["{{airframe}}"] }

# Cortex-M runtime (required for entry point)
cortex-m = { version = "0.7", features = ["critical-section-single-core"] }
cortex-m-rt = "0.7"
panic-halt = "1.0"

[build-dependencies]
# For compile-time config parsing
toml = "0.8"

[profile.release]
opt-level = "s"
lto = "thin"
debug = true
codegen-units = 1
{% endif %}
