//! {{project-name}} - Aviate SITL Application
//!
//! ## Usage
//!
//! ```bash
//! # Interactive mode (Gazebo with GUI, wait for GCS):
//! cargo run -p aviate-app-{{project-name}}
//!
//! # Headless mode (no GUI, wait for GCS):
//! cargo run -p aviate-app-{{project-name}} -- --headless
//!
//! # Test mode (run mission from TOML file):
//! cargo run -p aviate-app-{{project-name}} -- --test tests/missions/basic_flight.toml
//!
//! # Mock mode (no simulator, for unit testing):
//! cargo run -p aviate-app-{{project-name}} -- --mock
//! ```

use std::env;
use std::path::Path;
use std::process::ExitCode;

use log::{info, warn, error};

use aviate_board_{{board | replace: "-", "_"}}::*;

/// Command line options
struct Options {
    mock: bool,
    headless: bool,
    test_config: Option<String>,
    instance: u8,
    connect: bool,
}

impl Options {
    fn parse() -> Self {
        let args: Vec<String> = env::args().collect();

        let mock = args.iter().any(|a| a == "--mock");
        let headless = args.iter().any(|a| a == "--headless")
            || env::var("HEADLESS").map(|v| v == "1").unwrap_or(false);

        let test_config = args
            .iter()
            .position(|a| a == "--test")
            .and_then(|i| args.get(i + 1).cloned());

        let instance = args
            .iter()
            .position(|a| a == "--instance")
            .and_then(|i| args.get(i + 1))
            .and_then(|v| v.parse().ok())
            .or_else(|| env::var("AVIATE_INSTANCE").ok()?.parse().ok())
            .unwrap_or(0);

        let connect = args.iter().any(|a| a == "--connect");

        Self {
            mock,
            headless,
            test_config,
            instance,
            connect,
        }
    }
}


/// Kernel construction, owned by this app: the airframe pair is named
/// here, the full resolved configuration is assembled, and the checked
/// builder refuses a controller/config mismatch. Preset-file loading
/// replaces these literals when configuration-driven construction
/// lands.
fn build_kernel() -> Result<
    aviate_core::DefaultAviateKernel<
        aviate_core::control::multirotor::MultirotorController,
        aviate_core::mixer::QuadXMixerX500,
    >,
    aviate_core::kernel::builder::KernelBuildError,
> {
    use aviate_core::control::cascade_gains::CascadeGains;
    use aviate_core::control::multirotor::MultirotorController;
    use aviate_core::kernel::builder::AviateKernelBuilder;
    use aviate_core::kernel::config::ResolvedKernelConfig;
    use aviate_core::kernel::config::{ActuatorCurveKind, MixerGeometry};
    use aviate_core::mixer::{ModeConfig, QuadXMixerX500, Sanitizer};
    use aviate_core::types::NormalizedThrust;

    let gains = CascadeGains::x500_defaults();
    // Force-domain hover trim (#140): weight / max thrust for the
    // X500 (20.25 N / 34.19 N ≈ 0.5929; the quadratic boundary curve
    // commands √0.5929 = 0.77 of max rotor speed at trim).
    let hover = NormalizedThrust(0.5929);
    let cfg = ResolvedKernelConfig {
        cascade_gains: gains,
        hover_thrust_norm: hover,
        mixer_geometry: MixerGeometry::QuadXX500,
        actuator_curve: ActuatorCurveKind::QuadraticRotor,
        mode_config: ModeConfig {
            mode: aviate_core::control::ConfigMode::Hover,
            groups: &[],
        },
        ..ResolvedKernelConfig::default()
    };

    let mut kernel = AviateKernelBuilder::new()
        .estimator(aviate_core::ekf::Ekf::default())
        .controller(MultirotorController::from_gains(gains, hover.0))
        .mixer(QuadXMixerX500 {
            timestamp_source: sitl_timestamp,
        })
        .sanitizer(Sanitizer)
        .config(cfg)
        .build()?;
    kernel.state.checks.pre_arm.update_throttle(true);
    Ok(kernel)
}

fn main() -> ExitCode {
    let opts = Options::parse();
    let instance = opts.instance;

    // Custom log format with vehicle instance ID and colored levels
    env_logger::Builder::from_env(env_logger::Env::default().default_filter_or("info"))
        .format(move |buf, record| {
            use std::io::Write;
            let level_style = buf.default_level_style(record.level());
            writeln!(
                buf,
                "[{} {level_style}{}{level_style:#} fc{}] {}",
                buf.timestamp(),
                record.level(),
                instance,
                record.args()
            )
        })
        .init();

    // Load application configuration
    const APP_CONFIG_TOML: &str = include_str!("../AviateApp.toml");
    let app_config = match aviate_config::from_toml_str(APP_CONFIG_TOML) {
        Ok(config) => config,
        Err(_) => {
            error!("Failed to parse AviateApp.toml");
            return ExitCode::FAILURE;
        }
    };

    if aviate_config::validate(&app_config).is_err() {
        error!("Invalid configuration in AviateApp.toml");
        return ExitCode::FAILURE;
    }

    let headless = opts.headless || app_config.simulator
        .as_ref()
        .map(|s| s.headless)
        .unwrap_or(false);

    info!(
        "==> {} | board={} airframe={} instance={} <==",
        app_config.app.id,
        app_config.app.board,
        app_config.app.airframe,
        opts.instance
    );

    if opts.mock {
        info!("Mode: Mock (no simulator)");
        run_mock();
        ExitCode::SUCCESS
    } else if let Some(ref config_path) = opts.test_config {
        info!("Mode: Test ({})", config_path);
        run_test(config_path, opts.instance, headless)
    } else {
        info!(
            "Mode: Interactive (headless={}, connect={})",
            if headless { "yes" } else { "no" },
            opts.connect
        );
        run_interactive(headless, opts.instance, opts.connect, &app_config)
    }
}

fn run_mock() {
    use aviate_core::hal::SystemHal;
    use aviate_hal_xil::SitlHal;

    info!("Starting mock mode (no simulator)");
    let mut hal = SitlHal::new();

    loop {
        hal.kick_watchdog();
        std::thread::sleep(std::time::Duration::from_millis(10));
    }
}

#[cfg(feature = "gz-plugin")]
fn run_interactive(headless: bool, instance: u8, connect: bool, app_config: &aviate_config::AppConfig) -> ExitCode {
    use aviate_app_{{project-name | replace: "-", "_"}}::{generate_world, parse_test_config_str, WorldParams};
    use aviate_backend_gz::GzPluginBridge;
    use aviate_hal_xil::SitlConfig;
    use std::time::Duration;

    let config = SitlConfig::for_instance(instance);
    info!("Sensor port: {}", config.sensor_port());

    // Only launch Gazebo if not connecting to existing instance
    let gz_child = if !connect {
        // Generate a default world with single vehicle
        let test_config = parse_test_config_str(DEFAULT_WORLD_CONFIG).expect("valid default config");
        let world_params = WorldParams::default();

        let world_sdf = generate_world(&test_config, &world_params);
        let world_path = std::env::temp_dir().join("aviate_interactive.sdf");
        std::fs::write(&world_path, &world_sdf).expect("write world file");
        info!("World file: {}", world_path.display());

        cleanup_gazebo();

        match launch_gazebo(&world_path, headless) {
            Ok(child) => {
                info!("Gazebo started (PID: {}, headless={})", child.id(), headless);
                Some(child)
            }
            Err(e) => {
                warn!("Failed to launch Gazebo: {}", e);
                return ExitCode::FAILURE;
            }
        }
    } else {
        info!("Connecting to existing Gazebo instance...");
        None
    };

    info!("Waiting for Gazebo plugin...");
    if !wait_for_shm(Duration::from_secs(30)) {
        warn!("Timeout waiting for Gazebo plugin");
        if let Some(child) = gz_child { drop(child); }
        if !connect { cleanup_gazebo(); }
        return ExitCode::FAILURE;
    }
    info!("Gazebo ready");

    let mut board = match GazeboSitlBoard::with_config_retry(build_kernel, config, 5, 1000) {
        Ok(b) => b,
        Err(e) => {
            warn!("Failed to initialize board: {}", e);
             if let Some(child) = gz_child { drop(child); }
             if !connect { cleanup_gazebo(); }
            return ExitCode::FAILURE;
        }
    };

    // Initialize telemetry (GCS link)
    board.init_telemetry(app_config, 1000);
    info!("Telemetry initialized");

    let plugin = match GzPluginBridge::connect_instance_with_retry(instance, 20, 500) {
        Ok(p) => {
            info!("Connected to Gazebo plugin");
            p
        }
        Err(e) => {
            warn!("Failed to connect to Gazebo: {}", e);
             if let Some(child) = gz_child { drop(child); }
             if !connect { cleanup_gazebo(); }
            return ExitCode::FAILURE;
        }
    };

    info!("Flight controller ready - waiting for GCS commands");
    info!("");

    run_control_loop(&mut board, &plugin);

    if let Some(child) = gz_child { drop(child); }
    if !connect { cleanup_gazebo(); }
    ExitCode::SUCCESS
}

#[cfg(not(feature = "gz-plugin"))]
fn run_interactive(_headless: bool, _instance: u8, _connect: bool, _app_config: &aviate_config::AppConfig) -> ExitCode {
    warn!("gz-plugin feature not enabled");
    warn!("Rebuild with: cargo build -p aviate-app-{{project-name}} --features gz-plugin");
    ExitCode::FAILURE
}

#[cfg(feature = "gz-plugin")]
fn run_test(config_path: &str, _instance: u8, headless: bool) -> ExitCode {
    use aviate_app_{{project-name | replace: "-", "_"}}::{generate_temp_world, parse_test_config, WorldParams};
    use aviate_backend_gz::GazeboSimBackend;
    use aviate_hal_xil::run_test_config;
    use std::time::Duration;

    let config_file = Path::new(config_path);
    if !config_file.exists() {
        warn!("Config file not found: {}", config_path);
        return ExitCode::FAILURE;
    }

    let test_config = match parse_test_config(config_file) {
        Ok(c) => c,
        Err(e) => {
            warn!("Failed to parse config: {}", e);
            return ExitCode::FAILURE;
        }
    };

    info!("Test: {}", test_config.name);
    info!("Description: {}", test_config.description);
    info!("Vehicles: {}", test_config.vehicles.len());
    info!("");

    let world_params = WorldParams {
        lockstep: test_config.lockstep,
        ..WorldParams::default()
    };

    let world_path = match generate_temp_world(&test_config, &world_params) {
        Ok(p) => p,
        Err(e) => {
            warn!("Failed to generate world: {}", e);
            return ExitCode::FAILURE;
        }
    };
    info!("World file: {}", world_path.display());

    cleanup_gazebo();
    let gz_child = match launch_gazebo(&world_path, headless) {
        Ok(child) => {
            info!("Gazebo started (PID: {}, {})", child.id(), if headless { "headless" } else { "GUI" });
            child
        }
        Err(e) => {
            warn!("Failed to launch Gazebo: {}", e);
            return ExitCode::FAILURE;
        }
    };

    info!("Waiting for Gazebo plugin...");
    if !wait_for_shm(Duration::from_secs(30)) {
        warn!("Timeout waiting for Gazebo plugin");
        drop(gz_child);
        cleanup_gazebo();
        return ExitCode::FAILURE;
    }

    info!("Running {} vehicle(s)...", test_config.vehicles.len());
    let result = run_test_config(&test_config, |instance| {
        GazeboSimBackend::connect_new(instance, 10000)
    });

    info!("");
    info!("=== Test Results ===");
    info!("Test: {}", result.name);
    info!("Duration: {:.2}s", result.duration.as_secs_f32());
    info!("");

    for (i, vr) in result.vehicle_results.iter().enumerate() {
        info!("Vehicle {}: {} - {}", i, vr.mission_name, if vr.passed { "PASSED" } else { "FAILED" });
        info!("  Max Altitude: {:.2}m", vr.max_altitude);
    }
    info!("");

    drop(gz_child);
    cleanup_gazebo();

    if result.passed {
        info!("PASSED: {}", test_config.name);
        ExitCode::SUCCESS
    } else {
        info!("FAILED: {}", test_config.name);
        ExitCode::FAILURE
    }
}

#[cfg(not(feature = "gz-plugin"))]
fn run_test(_config_path: &str, _instance: u8, _headless: bool) -> ExitCode {
    warn!("gz-plugin feature not enabled");
    ExitCode::FAILURE
}

#[cfg(feature = "gz-plugin")]
fn launch_gazebo(world_path: &Path, headless: bool) -> Result<std::process::Child, std::io::Error> {
    use std::process::{Command, Stdio};

    let aviate_dir = env::current_dir().unwrap_or_default();

    let local_models = aviate_dir.join("models");
    let px4_models = aviate_dir.join("external/PX4-gazebo-models/models");
    let mut model_paths = Vec::new();
    if local_models.exists() {
        model_paths.push(local_models.to_string_lossy().to_string());
    }
    if px4_models.exists() {
        model_paths.push(px4_models.to_string_lossy().to_string());
    }
    let gz_resource_path = model_paths.join(":");

    let plugin_dir = aviate_dir.join("aviate-hal/xil/backends/gz/plugin/build");
    let gz_plugin_path = plugin_dir.to_string_lossy().to_string();

    let mut cmd = Command::new("gz");
    cmd.arg("sim");

    if headless {
        cmd.arg("-s").arg("-r").arg("--headless-rendering");
        cmd.env_remove("DISPLAY");
    } else {
        cmd.arg("-r");
    }

    cmd.arg(world_path);

    if !gz_resource_path.is_empty() {
        let existing = env::var("GZ_SIM_RESOURCE_PATH").unwrap_or_default();
        let combined = if existing.is_empty() { gz_resource_path } else { format!("{}:{}", gz_resource_path, existing) };
        cmd.env("GZ_SIM_RESOURCE_PATH", combined);
    }

    if !gz_plugin_path.is_empty() {
        let existing = env::var("GZ_SIM_SYSTEM_PLUGIN_PATH").unwrap_or_default();
        let combined = if existing.is_empty() { gz_plugin_path.clone() } else { format!("{}:{}", gz_plugin_path, existing) };
        cmd.env("GZ_SIM_SYSTEM_PLUGIN_PATH", combined);
        cmd.env("LD_LIBRARY_PATH", gz_plugin_path);
    }

    cmd.stdout(Stdio::null());
    cmd.stderr(Stdio::null());

    cmd.spawn()
}

#[cfg(feature = "gz-plugin")]
fn cleanup_gazebo() {
    use std::process::Command;
    let _ = Command::new("pkill").args(["-9", "-f", "gz sim"]).status();
    let _ = std::fs::remove_file("/dev/shm/aviate_gz_bridge");
    std::thread::sleep(std::time::Duration::from_millis(500));
}

#[cfg(feature = "gz-plugin")]
fn wait_for_shm(timeout: std::time::Duration) -> bool {
    use std::time::Instant;

    let shm_path = Path::new("/dev/shm/aviate_gz_bridge");
    let start = Instant::now();

    while start.elapsed() < timeout {
        if shm_path.exists() {
            return true;
        }
        std::thread::sleep(std::time::Duration::from_millis(250));
    }
    false
}

#[cfg(feature = "gz-plugin")]
fn run_control_loop(
    board: &mut GazeboSitlBoard<
        aviate_core::control::multirotor::MultirotorController,
        aviate_core::mixer::QuadXMixerX500,
    >,
    plugin: &aviate_backend_gz::GzPluginBridge,
) {
    use aviate_backend_gz::{enu_to_ned_f32, enu_vel_to_ned_f32};
    use aviate_hal_xil::{SimBaroData, SimGnssData, SimGnssFix, SimImuData, SimMagData, SimSensorPacket};

    let loop_period_us = 1000u64;
    let mut last_tick = board.now_us();
    let mut stats_tick = last_tick;
    let mut sensor_count = 0u64;
    let mut motor_count = 0u64;

    loop {
        let now = board.now_us();
        let elapsed = now.saturating_sub(last_tick);

        if elapsed >= loop_period_us {
            last_tick = now;

            if let Some(state) = plugin.get_model_state() {
                let ned_pos = enu_to_ned_f32(state.pos);
                let ned_vel = enu_vel_to_ned_f32(state.vel);

                let imu = SimImuData {
                    accel: [0.0, 0.0, -9.81],
                    gyro: [state.ang_vel[0] as f32, -state.ang_vel[1] as f32, -state.ang_vel[2] as f32],
                    temperature: Some(25.0),
                };

                let baro = SimBaroData {
                    pressure_pa: 101325.0 + ned_pos[2] * 12.0,
                    temperature_c: 25.0,
                };

                let mag = SimMagData { field_ut: [20.0, 0.0, 40.0] };

                let gnss = SimGnssData {
                    lat_deg: ned_pos[0] as f64 / 111000.0,
                    lon_deg: ned_pos[1] as f64 / 111000.0,
                    alt_m: -ned_pos[2],
                    position_ned: ned_pos,
                    vel_ned: ned_vel,
                    fix: SimGnssFix::ThreeD,
                    h_acc: 1.0,
                    v_acc: 1.5,
                    satellites: 10,
                };

                let packet = SimSensorPacket {
                    timestamp_us: state.time_us,
                    imu: Some(imu),
                    baro: Some(baro),
                    mag: Some(mag),
                    gnss: Some(gnss),
                };

                board.transport_mut().feed_sensor_packet(&packet);
                sensor_count += 1;
            }

            board.step();

            if let Some(cmd) = board.transport_mut().take_actuator_cmd() {
                const MAX_MOTOR_RADS: f64 = 1000.0;
                let velocities: Vec<f64> = cmd.outputs.iter().take(cmd.count as usize).map(|&v| (v as f64) * MAX_MOTOR_RADS).collect();
                let _ = plugin.set_motor_speeds(&velocities);
                motor_count += 1;
            }

            if now.saturating_sub(stats_tick) >= 5_000_000 {
                stats_tick = now;
                info!("sensors={}, motors={}, armed={}", sensor_count, motor_count, board.is_armed());
            }
        } else {
            let remaining_us = loop_period_us - elapsed;
            if remaining_us > 100 {
                std::thread::sleep(std::time::Duration::from_micros(remaining_us - 100));
            }
        }
    }
}

// Default world config for interactive mode
const DEFAULT_WORLD_CONFIG: &str = r#"
name = "interactive"
description = "Interactive flight mode"
lockstep = false

[[vehicles]]
id = "{{model}}"
model = "{{model}}"
instance = 0
spawn_position = [0.0, 0.0, 0.1]
spawn_heading = 0.0

[vehicles.mission]
name = "manual"
phases = []
"#;
{% elsif env == "flight" %}
//! {{project-name}} - Aviate Flight Application
//!
//! ## Architecture
//!
//! This app uses the same `FlightRunner` as SITL, but with:
//! - Real hardware (STM32H743)
//! - Phase 1: HIL mode with FakeSensors fed via MAVLink
//! - Phase 3: Real sensors (BMI088, SPL06)
//!
//! ## Build & Flash
//!
//! ```bash
//! cargo build --release
//! cargo xtask flash {{project-name}}
//! ```
//!
//! ## HIL Testing
//!
//! Connect via USB CDC and send MAVLink HIL_SENSOR messages:
//! ```bash
//! mavproxy.py --master=/dev/ttyACM0
//! ```

#![no_std]
#![no_main]
// DO-178C compliance: forbid panic-prone code
#![deny(clippy::panic)]
#![deny(clippy::unwrap_used)]
#![deny(clippy::expect_used)]

use panic_halt as _;
use cortex_m_rt::entry;

// Board support crate (provides PAC, pin configs, sensor configs)
use aviate_board_{{board | replace: "-", "_"}} as board;

// Include compile-time generated config (from build.rs)
include!(concat!(env!("OUT_DIR"), "/app_config.rs"));

#[entry]
fn main() -> ! {
    // Take peripherals (links interrupt vectors via board::hal::pac)
    // Safety: entry point, peripherals can only be taken once
    // Use match instead of unwrap() for DO-178C compliance
    let dp = match board::hal::pac::Peripherals::take() {
        Some(p) => p,
        None => loop { cortex_m::asm::wfi(); },
    };
    let cp = match cortex_m::Peripherals::take() {
        Some(p) => p,
        None => loop { cortex_m::asm::wfi(); },
    };

    // Read board info and config to verify they're available
    let _ = board::BOARD_INFO.name;
    let _ = APP_ID;

    // Create board and runner
    // Phase 1: Uses FakeSensors for HIL testing on real MCU
    // Phase 3+: Will use real sensor drivers
    #[cfg(feature = "flight")]
    {
        // FlightBoard is a generic type alias exported by all boards for template compatibility
        let flight_board = board::hw::FlightBoard::new(dp, cp);
        let mut runner = flight_board.into_runner();

        // Run control loop at configured rate (typically 1kHz = 1000us period)
        runner.run(LOOP_PERIOD_US);
    }

    // Fallback for builds without flight feature (should not happen in normal builds)
    #[cfg(not(feature = "flight"))]
    {
        let _ = dp;
        let _ = cp;
        loop {
            cortex_m::asm::wfi();
        }
    }
}
{% endif %}
