//! {{project-name}} - Aviate SITL Application (jMAVSim)
//!
//! Run with: cargo run -p aviate-app-{{project-name}}

use std::process::ExitCode;

use aviate_board_sitl_jmavsim::JmavSimBoard;

fn main() -> ExitCode {
    const APP_CONFIG_TOML: &str = include_str!("../AviateApp.toml");
    let app_config = match aviate_config::from_toml_str(APP_CONFIG_TOML) {
        Ok(config) => config,
        Err(_) => {
            eprintln!("[ERROR] Failed to parse AviateApp.toml");
            return ExitCode::FAILURE;
        }
    };

    println!("===========================================");
    println!("  {{project-name}}");
    println!("===========================================");
    println!();
    println!("App ID:   {}", app_config.app.id);
    println!("Board:    {}", app_config.app.board);
    println!("Airframe: {}", app_config.app.airframe);
    println!("Env:      {}", app_config.app.env);
    println!();

    eprintln!("[INFO] Starting jMAVSim SITL...");

    let mut board = match JmavSimBoard::new() {
        Ok(b) => b,
        Err(e) => {
            eprintln!("[ERROR] Failed to initialize board: {}", e);
            return ExitCode::FAILURE;
        }
    };

    eprintln!("[INFO] Sending handshake to jMAVSim...");
    board.send_handshake();

    board.run()
}
