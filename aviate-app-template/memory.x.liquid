/* Memory layout for STM32H743 with Aviate bootloader
 * Bootloader occupies 0x08000000-0x0801FFFF (128KB)
 * Application starts at 0x08020000
 */
MEMORY
{
    FLASH : ORIGIN = 0x08020000, LENGTH = 1920K  /* 2MB - 128KB bootloader */
    RAM   : ORIGIN = 0x20000000, LENGTH = 128K   /* DTCM - fast, stack/bss here */
    AXISRAM : ORIGIN = 0x24000000, LENGTH = 512K /* AXI SRAM for heap/large buffers */
}

/* Stack at end of RAM (DTCM) */
_stack_start = ORIGIN(RAM) + LENGTH(RAM);
